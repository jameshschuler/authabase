{
    "name": "@authabase/react",
    "type": "module",
    "version": "0.1.0",
    "description": "Reusable React auth components with Supabase integration, shadcn UI, and configurable auth methods",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "module": "dist/index.esm.js",
    "exports": {
        ".": {
            "import": "./dist/index.esm.js",
            "require": "./dist/index.js",
            "types": "./dist/index.d.ts"
        },
        "./components": {
            "import": "./dist/components/index.esm.js",
            "require": "./dist/components/index.js",
            "types": "./dist/components/index.d.ts"
        },
        "./provider": {
            "import": "./dist/provider/index.esm.js",
            "require": "./dist/provider/index.js",
            "types": "./dist/provider/index.d.ts"
        },
        "./types": {
            "import": "./dist/types/index.esm.js",
            "require": "./dist/types/index.js",
            "types": "./dist/types/index.d.ts"
        }
    },
    "files": [
        "dist",
        "README.md",
        "LICENSE"
    ],
    "scripts": {
        "dev": "vite",
        "build": "tsc && vite build",
        "build:watch": "vite build --watch",
        "preview": "vite preview",
        "lint": "eslint src --ext .ts,.tsx",
        "lint:fix": "eslint src --ext .ts,.tsx --fix",
        "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
        "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\"",
        "test": "vitest",
        "test:ui": "vitest --ui",
        "test:coverage": "vitest --coverage",
        "type-check": "tsc --noEmit"
    },
    "dependencies": {
        "@base-ui/react": "^1.0.0",
        "@supabase/supabase-js": "^2.39.0",
        "class-variance-authority": "^0.7.0",
        "clsx": "^2.0.0",
        "react": "^19.0.0",
        "react-dom": "^19.0.0",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.0",
        "@fortawesome/fontawesome-svg-core": "^7.2.0",
        "@fortawesome/free-brands-svg-icons": "^7.2.0",
        "@fortawesome/free-solid-svg-icons": "^7.2.0",
        "@fortawesome/react-fontawesome": "^3.3.1",
        "@tailwindcss/postcss": "^4.2.4",
        "@tailwindcss/vite": "^4.2.4",
        "@testing-library/dom": "^10.4.1",
        "@testing-library/jest-dom": "^6.1.5",
        "@testing-library/react": "^16.3.0",
        "@testing-library/user-event": "^14.5.1",
        "@types/node": "^25.0.0",
        "@types/react": "^19.0.0",
        "@types/react-dom": "^19.0.0",
        "@typescript-eslint/eslint-plugin": "^8.0.0",
        "@typescript-eslint/parser": "^8.0.0",
        "@vitejs/plugin-react": "^6.0.0",
        "@vitest/ui": "^4.1.0",
        "autoprefixer": "^10.4.16",
        "eslint": "^10.0.0",
        "eslint-config-prettier": "^10.0.0",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-react-hooks": "^7.1.0",
        "jsdom": "^29.0.0",
        "postcss": "^8.4.32",
        "prettier": "^3.1.1",
        "tailwindcss": "^4.2.0",
        "typescript": "^6.0.0",
        "typescript-eslint": "^8.59.0",
        "vite": "^8.0.0",
        "vitest": "^4.1.0"
    },
    "peerDependencies": {
        "@fortawesome/fontawesome-svg-core": "^7.2.0",
        "@fortawesome/react-fontawesome": "^3.3.0",
        "react": "^19.0.0",
        "react-dom": "^19.0.0"
    },
    "keywords": [
        "react",
        "auth",
        "authentication",
        "supabase",
        "components",
        "typescript"
    ],
    "author": "Your Name",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/yourusername/authabase"
    }
}